html {
  font-size: 14px;
  position: relative;
  min-height: 100%;
}

@media (min-width: 768px) {
  html {
    font-size: 15px;
  }
}

:root {
  --surface: #ffffff;
  --surface-alt: #f6f8fb;
  --border: #d9e0e8;
  --text: #1f2937;
  --muted: #6b7280;
  --primary: #1d4ed8;
  --primary-hover: #1e40af;
}

.btn:focus,
.btn:active:focus,
.btn-link.nav-link:focus,
.form-control:focus,
.form-check-input:focus {
  box-shadow: 0 0 0 0.1rem #fff, 0 0 0 0.2rem rgba(29, 78, 216, 0.2);
}

body {
  min-height: 100%;
  margin-bottom: 0;
  color: var(--text);
  background: var(--surface-alt);
}

.site-header,
.site-footer {
  background: var(--surface);
}

.navbar-brand {
  font-weight: 700;
  letter-spacing: -0.02em;
}

.navbar .nav-link {
  color: var(--text);
  padding: 0.45rem 0.7rem;
}

.navbar .nav-link:hover,
.navbar .nav-link:focus,
.navbar .nav-link.active,
.nav-link--muted:hover,
.nav-link--muted:focus {
  color: var(--primary);
}

.nav-link--muted {
  color: var(--muted);
}

.nav-cta {
  padding-left: 0.9rem;
  padding-right: 0.9rem;
}

.site-footer {
  font-size: 0.9rem;
}

.site-footer a {
  color: var(--muted);
  text-decoration: none;
}

.site-footer a:hover {
  color: var(--primary);
}

.page-section,
.landing-page,
.auth-page {
  display: grid;
  gap: 0.85rem;
}

.section-card,
.info-card,
.auth-shell {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 0.75rem;
}

.section-card {
  padding: 1.1rem 1.15rem;
}

.section-header {
  display: grid;
  gap: 0.35rem;
}

.section-header--row {
  grid-template-columns: 1fr auto;
  align-items: start;
  gap: 0.9rem;
}

.section-label {
  margin: 0;
  color: var(--muted);
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.section-header h1 {
  margin: 0;
  font-size: 1.35rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.section-text {
  margin: 0;
  color: var(--muted);
  max-width: 68ch;
}

.action-row {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: 0.4rem;
}

.action-row .btn {
  padding-left: 0.9rem;
  padding-right: 0.9rem;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 0.85rem;
}

.info-card {
  padding: 0.95rem 1rem;
}

.info-card h2 {
  margin: 0 0 0.3rem;
  font-size: 0.98rem;
  font-weight: 700;
}

.info-card p {
  margin: 0;
  color: var(--muted);
}

.landing-hero,
.auth-shell {
  padding: 1.15rem;
}

.landing-hero {
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.8fr);
  gap: 1rem;
  align-items: center;
}

.landing-copy h1,
.auth-copy h1 {
  margin: 0;
  font-size: 1.45rem;
  font-weight: 700;
  letter-spacing: -0.02em;
}

.landing-summary {
  display: grid;
  gap: 0.65rem;
}

.summary-chip {
  padding: 0.7rem 0.85rem;
  border: 1px solid var(--border);
  border-radius: 0.7rem;
  background: var(--surface-alt);
  text-align: center;
}

.summary-chip strong {
  display: block;
  font-size: 0.98rem;
  font-weight: 700;
  line-height: 1.1;
}

.summary-chip span {
  color: var(--muted);
  font-size: 0.8rem;
}

.summary-chip--price {
  min-width: 112px;
}

.summary-chip--stacked {
  text-align: left;
}

.products-table thead th {
  padding-top: 0;
  color: var(--muted);
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.04em;
  border-bottom: 1px solid var(--border);
}

.products-table tbody td {
  padding-top: 0.85rem;
  padding-bottom: 0.85rem;
  border-top: 1px solid var(--border);
}

.products-table .text-muted {
  color: var(--muted) !important;
}

.details-list {
  margin-top: 0.95rem;
  border-top: 1px solid var(--border);
}

.details-list div {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--border);
}

.details-list div:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.details-list span {
  color: var(--muted);
}

.details-list strong {
  font-weight: 700;
}

.auth-shell {
  display: grid;
  gap: 1rem;
}

.auth-form,
.checkout-form {
  display: grid;
  gap: 0.9rem;
}

.field-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 0.75rem;
}

.field-grid--two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.form-field {
  display: grid;
  gap: 0.35rem;
}

.form-field span {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--muted);
}

.form-field .form-control {
  border-radius: 0.6rem;
  border-color: var(--border);
}

.form-field .form-control::placeholder {
  color: #9aa3af;
}

.field-span-2 {
  grid-column: 1 / -1;
}

.auth-actions {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-top: 0.15rem;
}

.cart-total {
  display: grid;
  gap: 0.5rem;
  margin-top: 0.95rem;
  padding-top: 0.95rem;
  border-top: 1px solid var(--border);
}

.cart-total > div {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
}

.cart-total span {
  color: var(--muted);
}

.cart-total strong {
  font-weight: 700;
}

@media (max-width: 767.98px) {
  .landing-hero,
  .section-header--row,
  .field-grid--two {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 575.98px) {
  .summary-chip {
    width: fit-content;
  }
}