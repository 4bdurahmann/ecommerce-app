using CartFlow.Data.Entities;
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;

namespace CartFlow.Data.Data.Configurations {
    public class CartConfiguration : IEntityTypeConfiguration<Cart> {
        public void Configure(EntityTypeBuilder<Cart> builder) {
            builder.HasKey(c => c.Id);

            builder.HasOne(c => c.User)
                .WithMany()
                .HasForeignKey(c => c.UserId)
                .OnDelete(DeleteBehavior.Cascade);

            builder.ToTable("Carts");
            LoadData(builder);
        }

        private void LoadData(EntityTypeBuilder<Cart> builder) {
            builder.HasData(
                new Cart { Id = 1, UserId = 1 },
                new Cart { Id = 2, UserId = 2 },
                new Cart { Id = 3, UserId = 3 },
                new Cart { Id = 4, UserId = 4 },
                new Cart { Id = 5, UserId = 5 }
            );
        }
    }
}