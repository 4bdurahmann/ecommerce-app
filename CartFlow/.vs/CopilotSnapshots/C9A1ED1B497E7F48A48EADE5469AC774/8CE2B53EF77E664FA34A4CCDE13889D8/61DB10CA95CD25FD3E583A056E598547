using CartFlow.Data.Entities;
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;

namespace CartFlow.Data.Data.Configurations {
    public class CategoryConfiguration : IEntityTypeConfiguration<Category> {
        public void Configure(EntityTypeBuilder<Category> builder) {
            builder.HasKey(c => c.Id);

            builder.Property(c => c.Name)
                .HasMaxLength(100)
                .IsRequired();

            builder.Property(c => c.Descripion)
                .HasMaxLength(500);

            builder.HasOne(c => c.ParentCategory)
                .WithMany()
                .HasForeignKey(c => c.ParentCategoryId)
                .OnDelete(DeleteBehavior.Restrict);

            builder.ToTable("Categories");
            LoadData(builder);
        }

        private void LoadData(EntityTypeBuilder<Category> builder) {
            builder.HasData(
                new Category { Id = 1, Name = "Egyptian Cotton", Descripion = "Premium 100% Egyptian Cotton Clothing and Textiles" },
                new Category { Id = 2, Name = "Local Sweets", Descripion = "Delicious Oriental and Egyptian Desserts" },
                new Category { Id = 3, Name = "Handcrafts", Descripion = "Traditional Egyptian Pottery and Copper works" },
                new Category { Id = 4, Name = "Spices & Groceries", Descripion = "Authentic Egyptian Spices and Foods" },
                new Category { Id = 5, Name = "Electronics", Descripion = "Locally assembled electronics and appliances" }
            );
        }
    }
}