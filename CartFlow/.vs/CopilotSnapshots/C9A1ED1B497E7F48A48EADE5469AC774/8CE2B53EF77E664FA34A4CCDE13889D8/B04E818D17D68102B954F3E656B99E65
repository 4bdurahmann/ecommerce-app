using CartFlow.Data.Entities;
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;

namespace CartFlow.Data.Data.Configurations {
    public class OrderItemConfiguration : IEntityTypeConfiguration<OrderItem> {
        public void Configure(EntityTypeBuilder<OrderItem> builder) {
            builder.HasKey(oi => oi.Id);

            builder.HasOne(oi => oi.Order)
                .WithMany(o => o.OrderItems)
                .HasForeignKey(oi => oi.OrderId)
                .OnDelete(DeleteBehavior.Cascade);

            builder.HasOne(oi => oi.Product)
                .WithMany(p => p.OrderItems)
                .HasForeignKey(oi => oi.ProductId)
                .OnDelete(DeleteBehavior.Restrict);

            builder.ToTable("OrderItems");
            LoadData(builder);
        }

        private void LoadData(EntityTypeBuilder<OrderItem> builder) {
            builder.HasData(
                new OrderItem { Id = 1, OrderId = 1, ProductId = 1, Quantity = 2, Price = 250.00m },
                new OrderItem { Id = 2, OrderId = 2, ProductId = 2, Quantity = 1, Price = 300.00m },
                new OrderItem { Id = 3, OrderId = 3, ProductId = 3, Quantity = 1, Price = 150.00m },
                new OrderItem { Id = 4, OrderId = 4, ProductId = 4, Quantity = 5, Price = 45.00m },
                new OrderItem { Id = 5, OrderId = 5, ProductId = 5, Quantity = 1, Price = 3500.00m }
            );
        }
    }
}