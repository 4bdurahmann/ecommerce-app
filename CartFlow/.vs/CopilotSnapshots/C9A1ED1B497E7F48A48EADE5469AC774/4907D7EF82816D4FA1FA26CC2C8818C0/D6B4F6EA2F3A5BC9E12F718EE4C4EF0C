using CartFlow.Data.Entities;
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;

namespace CartFlow.Data.Data.Configurations {
    public class OrderConfiguration : IEntityTypeConfiguration<Order> {
        public void Configure(EntityTypeBuilder<Order> builder) {
            builder.HasKey(o => o.Id);

            builder.Property(o => o.PaymentMethod)
                .HasConversion<string>()
                .IsRequired()
                .HasMaxLength(10);

            builder.Property(o => o.OrderStatus)
                .HasConversion<string>()
                .HasMaxLength(20);

            builder.HasOne(o => o.User)
                .WithMany()
                .HasForeignKey(o => o.UserId)
                .OnDelete(DeleteBehavior.Cascade);

            builder.ToTable("Orders");
            LoadData(builder);
        }

        private void LoadData(EntityTypeBuilder<Order> builder) {
            var date = new System.DateTime(2024, 1, 1, 0, 0, 0, System.DateTimeKind.Utc);
            builder.HasData(
                new Order { Id = 1, UserId = 2, PaymentMethod = PaymentMethod.Cash, TotalPrice = 500.00m, TotalQuantity = 2, OrderStatus = Status.Delivered, OrderDate = date },
                new Order { Id = 2, UserId = 3, PaymentMethod = PaymentMethod.Credit, TotalPrice = 300.00m, TotalQuantity = 1, OrderStatus = Status.Shipped, OrderDate = date },
                new Order { Id = 3, UserId = 4, PaymentMethod = PaymentMethod.Cash, TotalPrice = 150.00m, TotalQuantity = 1, OrderStatus = Status.Ordered, OrderDate = date },
                new Order { Id = 4, UserId = 5, PaymentMethod = PaymentMethod.Cash, TotalPrice = 225.00m, TotalQuantity = 5, OrderStatus = Status.Cancelled, OrderDate = date },
                new Order { Id = 5, UserId = 1, PaymentMethod = PaymentMethod.Credit, TotalPrice = 3500.00m, TotalQuantity = 1, OrderStatus = Status.Delivered, OrderDate = date }
            );
        }
    }
}