using CartFlow.Data.Entities;
using Microsoft.EntityFrameworkCore;
using Microsoft.EntityFrameworkCore.Metadata.Builders;
using static CartFlow.Data.Entities.User;

namespace CartFlow.Data.Data.Configurations {
    public class UserConfiguration : IEntityTypeConfiguration<User> {
        public void Configure(EntityTypeBuilder<User> builder) {
            builder.HasKey(e => e.Id);

            builder.Property(e => e.FirstName)
                .HasMaxLength(100)
                .IsRequired();

            builder.Property(e => e.LastName)
                .HasMaxLength(100)
                .IsRequired();

            builder.Property(e => e.Email)
                .HasMaxLength(255)
                .IsRequired();

            builder.HasIndex(u => u.Email)
                .IsUnique();

            builder.Property(e => e.Password)
                .HasMaxLength(255)
                .IsRequired();

            builder.Property(u => u.UserRole)
                .HasConversion<string>()
                .IsRequired();

            builder.Property(e => e.Phone)
                .HasMaxLength(11);

            builder.ToTable("Users");
            LoadData(builder);
        }

        private void LoadData(EntityTypeBuilder<User> builder) {
            builder.HasData(
                new User { Id = 1, FirstName = "Ahmed", LastName = "Hassan", Email = "ahmed.hassan@example.com", Password = "password123", Phone = "01000000001", UserRole = Role.ADMIN },
                new User { Id = 2, FirstName = "Mohamed", LastName = "Ali", Email = "mohamed.ali@example.com", Password = "password123", Phone = "01100000002", UserRole = Role.CUSTOMER },
                new User { Id = 3, FirstName = "Fatma", LastName = "Ibrahim", Email = "fatma.ibrahim@example.com", Password = "password123", Phone = "01200000003", UserRole = Role.CUSTOMER },
                new User { Id = 4, FirstName = "Mahmoud", LastName = "Sayed", Email = "mahmoud.sayed@example.com", Password = "password123", Phone = "01500000004", UserRole = Role.CUSTOMER },
                new User { Id = 5, FirstName = "Aisha", LastName = "Mostafa", Email = "aisha.mostafa@example.com", Password = "password123", Phone = "01011111111", UserRole = Role.CUSTOMER }
            );
        }
    }
}
