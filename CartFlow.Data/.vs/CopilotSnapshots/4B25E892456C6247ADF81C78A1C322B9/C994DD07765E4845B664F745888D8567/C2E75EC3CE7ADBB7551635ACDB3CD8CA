@model Product

@{
    ViewData["Title"] = "Product Details";
}

<h1>@ViewData["Title"]</h1>

<div class="card">
    <div class="card-body">
        <h2 class="card-title">@Model.Name</h2>
        <h6 class="card-subtitle mb-3 text-muted">@Model.Category?.Name</h6>
        <p class="card-text">@Model.Description</p>

        <dl class="row mb-0">
            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Model.UnitPrice.ToString("C")</dd>

            <dt class="col-sm-3">Stock</dt>
            <dd class="col-sm-9">@Model.StockQuantity</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index">Back to Products</a>
</div>
