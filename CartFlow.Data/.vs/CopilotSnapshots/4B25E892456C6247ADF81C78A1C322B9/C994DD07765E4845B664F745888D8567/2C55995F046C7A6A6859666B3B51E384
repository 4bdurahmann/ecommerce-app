html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

:root {
  --surface: #ffffff;
  --surface-muted: #f8fafc;
  --border: #e5e7eb;
  --text: #0f172a;
  --muted: #64748b;
  --primary: #2563eb;
  --primary-strong: #1d4ed8;
  --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem #258cfb;
}

html {
  position: relative;
  min-height: 100%;
}

body {
  margin-bottom: 60px;
  color: var(--text);
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
}

.navbar {
  backdrop-filter: blur(10px);
}

.navbar-brand {
  font-weight: 700;
  letter-spacing: -0.02em;
}

.page-kicker {
  display: inline-block;
  margin-bottom: 0.75rem;
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.1);
  color: var(--primary);
  font-size: 0.85rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

.products-page,
.product-details {
  display: grid;
  gap: 1.5rem;
}

.page-hero,
.details-hero,
.details-panel,
.product-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 1.25rem;
  box-shadow: var(--shadow);
}

.page-hero,
.details-hero {
  padding: 1.75rem;
  display: flex;
  justify-content: space-between;
  gap: 1.5rem;
  align-items: center;
}

.page-hero h1,
.details-hero h1 {
  margin-bottom: 0.5rem;
  font-weight: 800;
  letter-spacing: -0.03em;
}

.page-hero p,
.details-hero p,
.details-panel p,
.product-card p {
  color: var(--muted);
  margin-bottom: 0;
}

.hero-stats,
.details-price {
  display: grid;
  gap: 0.75rem;
  min-width: 170px;
}

.hero-stats > div,
.details-price {
  padding: 1rem 1.25rem;
  border-radius: 1rem;
  background: var(--surface-muted);
  border: 1px solid var(--border);
}

.hero-stats strong,
.details-price strong {
  display: block;
  font-size: 1.35rem;
  font-weight: 800;
}

.hero-stats span,
.details-price span {
  color: var(--muted);
  font-size: 0.9rem;
}

.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1.25rem;
}

.product-card {
  overflow: hidden;
}

.product-card__image {
  min-height: 140px;
  padding: 1rem;
  display: flex;
  align-items: flex-start;
  justify-content: flex-end;
  background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
}

.product-card__image span {
  display: inline-flex;
  align-items: center;
  padding: 0.35rem 0.75rem;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.85);
  font-size: 0.85rem;
  font-weight: 600;
}

.product-card__body {
  padding: 1.25rem;
}

.product-card__header,
.product-card__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.product-card__header h2 {
  margin-bottom: 0;
  font-size: 1.1rem;
  font-weight: 700;
}

.price-badge {
  padding: 0.4rem 0.7rem;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.1);
  color: var(--primary-strong);
  font-weight: 700;
  white-space: nowrap;
}

.product-card__body p {
  margin: 0.85rem 0 1rem;
}

.product-card__meta {
  color: var(--muted);
  font-size: 0.92rem;
}

.details-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.25rem;
}

.details-panel {
  padding: 1.5rem;
}

.details-panel--accent {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-strong) 100%);
  color: #fff;
}

.details-panel--accent p {
  color: rgba(255, 255, 255, 0.82);
}

.details-panel--accent .btn-light {
  font-weight: 700;
}

.details-list {
  display: grid;
  gap: 1rem;
  margin-bottom: 0;
}

.details-list div {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}

.details-list div:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.details-list dt {
  color: var(--muted);
  font-weight: 600;
}

.details-list dd {
  margin-bottom: 0;
  font-weight: 700;
}

.form-floating > .form-control-plaintext::placeholder, .form-floating > .form-control::placeholder {
  color: var(--bs-secondary-color);
  text-align: end;
}

.form-floating > .form-control-plaintext:focus::placeholder, .form-floating > .form-control:focus::placeholder {
  text-align: start;
}